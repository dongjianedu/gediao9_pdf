# 格调九问 LLM 配置
# 将此文件重命名为 .env 并填入实际值

OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
MODEL=deepseek-v4-pro

# 阿里云 OSS 配置（生成后上传 PDF 并返回链接；不配置则生成接口会报错）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=gediao9
# 可选：OSS 访问点完整 URL
OSS_ACCESS_POINT_URL=

# 文件上传整理接口使用的根目录（可选，默认项目内 gediao_temp_content）
INPUT_BASE_DIR=

# 允许访问的前端来源（逗号分隔，部署前端时填入 Vercel 域名）
ALLOWED_ORIGINS=
